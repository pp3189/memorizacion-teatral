# =====================================================================
#  Variables de entorno — MétodoActor
#  Copia este archivo como ".env.local" (desarrollo) y configura las
#  mismas variables en Vercel (Project Settings > Environment Variables).
# =====================================================================

# URL del proyecto Supabase (Settings > API > Project URL)
VITE_SUPABASE_URL="https://TU-PROYECTO.supabase.co"

# Clave pública anónima de Supabase (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY="TU_ANON_KEY"

# (Opcional) Contraseña de administrador para el MODO LOCAL, cuando NO
# se configura Supabase. En producción usa Supabase Auth y puedes omitirla.
# VITE_ADMIN_PASSWORD="admin123"
